      "items": {
        "type": "string",
        "enum": [
          "qualified_opinion",
          "going_concern",
          "internal_control",
          "liquidity_stress",
          "refinancing_risk",
          "covenant_default",
          "impairment_loss",
          "legal_regulatory",
          "other_warning"
